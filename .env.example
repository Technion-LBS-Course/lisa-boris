# PyroFinder environment configuration
# Copy this file to .env and fill in values as needed.
# Never commit .env to Git.

PYROFINDER_ENV=development

# Paths
DATA_DIR=./data
MODEL_DIR=./models

# Model configuration
DEFAULT_MODEL_NAME=yolo11s
BASELINE_MODEL_NAME=yolo11n

# Detection settings
CONFIDENCE_THRESHOLD=0.5
CONFIRMATION_FRAMES=3

# Map defaults (Tel Aviv area as example — replace with actual site)
MAP_DEFAULT_LAT=32.0853
MAP_DEFAULT_LON=34.7818
